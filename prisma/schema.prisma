generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("active")
  metadata    String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  interactions Interaction[]
  actionItems  ActionItem[]
}

model Person {
  id           String    @id @default(cuid())
  name         String
  email        String?
  title        String?
  organization String?
  notes        String?
  metadata     String?
  source       String    @default("manual")
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  interactions InteractionPerson[]
  actionItems  ActionItemPerson[]
}

model Interaction {
  id            String    @id @default(cuid())
  type          String
  subject       String
  date          DateTime
  rawContent    String?
  parsedContent String?
  metadata      String?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  people      InteractionPerson[]
  actionItems ActionItem[]
  aiJobs      AiJob[]
  topics      InteractionTopic[]
  suggestions Suggestion[]
}

model ActionItem {
  id          String    @id @default(cuid())
  description String
  status      String    @default("open")
  dueDate     DateTime?
  priority    String?
  metadata    String?
  source      String    @default("manual") // manual | ai
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  interactionId String?
  interaction   Interaction? @relation(fields: [interactionId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  people ActionItemPerson[]
}

model AiJob {
  id            String    @id @default(cuid())
  status        String    @default("pending")
  result        String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  interactionId String
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
  suggestions   Suggestion[]
}

model InteractionPerson {
  interactionId String
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
  personId      String
  person        Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  @@id([interactionId, personId])
}

model ActionItemPerson {
  actionItemId String
  actionItem   ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  personId     String
  person       Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  @@id([actionItemId, personId])
}

model Topic {
  id          String    @id @default(cuid())
  name        String
  description String?
  metadata    String?
  source      String    @default("manual") // manual | ai
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  interactions InteractionTopic[]
}

model InteractionTopic {
  id            String   @id @default(cuid())
  startTime     DateTime
  endTime       DateTime
  summary       String?
  messageRange  String?
  interactionId String
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
  topicId       String
  topic         Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  @@unique([interactionId, topicId])
}

model Suggestion {
  id             String    @id @default(cuid())
  type           String    // person | action-item | topic-name
  payload        String
  status         String    @default("pending")
  linkedEntityId String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())

  aiJobId       String
  aiJob         AiJob @relation(fields: [aiJobId], references: [id], onDelete: Cascade)
  interactionId String
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
}
