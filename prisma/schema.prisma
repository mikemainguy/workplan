generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("active") // active, paused, completed
  metadata    String?   // JSON string for flexible AI-extracted data
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  interactions Interaction[]
  actionItems  ActionItem[]
}

model Person {
  id           String    @id @default(cuid())
  name         String
  email        String?
  title        String?   // role/job title
  organization String?
  notes        String?
  metadata     String?   // JSON string for flexible AI-extracted data
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  interactions InteractionPerson[]
  actionItems  ActionItemPerson[]
}

model Interaction {
  id            String    @id @default(cuid())
  type          String    // meeting, chat, in-person, other
  subject       String
  date          DateTime
  rawContent    String?   // original pasted text
  parsedContent String?   // structured/cleaned version
  metadata      String?   // JSON string for AI-extracted data
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  people      InteractionPerson[]
  actionItems ActionItem[]
  aiJobs      AiJob[]
  topics      InteractionTopic[]
}

model ActionItem {
  id          String    @id @default(cuid())
  description String
  status      String    @default("open") // open, in-progress, done, cancelled
  dueDate     DateTime?
  priority    String?   // low, medium, high, urgent
  metadata    String?   // JSON string for AI-extracted data
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  interactionId String?
  interaction   Interaction? @relation(fields: [interactionId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  people ActionItemPerson[]
}

model AiJob {
  id            String    @id @default(cuid())
  status        String    @default("pending")
  result        String?   // JSON: {summary, attendees, actionItems}
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  interactionId String
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
}

model InteractionPerson {
  interactionId String
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([interactionId, personId])
}

model ActionItemPerson {
  actionItemId String
  actionItem   ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([actionItemId, personId])
}

model Topic {
  id          String    @id @default(cuid())
  name        String
  description String?
  metadata    String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  interactions InteractionTopic[]
}

model InteractionTopic {
  id           String   @id @default(cuid())
  startTime    DateTime
  endTime      DateTime
  summary      String?
  messageRange String?  // JSON: {startIdx, endIdx}

  interactionId String
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  topicId String
  topic   Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([interactionId, topicId])
}
